# Brick complexity classifier — GPU variant.
# Built with CUDA 12.1 runtime to match the cu121 torch wheels in
# requirements-gpu.txt. Compatible with NVIDIA Container Toolkit on Linux,
# Docker Desktop WSL2 backend on Windows 11, and SkyPilot/Seeweb GPU clusters.

FROM nvidia/cuda:12.1.1-runtime-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive \
    PIP_NO_CACHE_DIR=1 \
    PYTHONUNBUFFERED=1 \
    HF_HOME=/root/.cache/huggingface

RUN apt-get update && apt-get install -y --no-install-recommends \
        python3 python3-pip curl ca-certificates git \
    && ln -sf /usr/bin/python3 /usr/bin/python \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements-gpu.txt .
RUN pip install --upgrade pip \
    && pip install -r requirements-gpu.txt

# Optional pre-cache at build time. Pass HF_TOKEN as build arg if the model is
# gated on the user's HF account; otherwise the first runtime call downloads.
ARG HF_TOKEN=""
RUN if [ -n "$HF_TOKEN" ]; then hf auth login --token "$HF_TOKEN" --add-to-git-credential || true; fi \
    && hf download regolo/brick-complexity-extractor \
    && hf download Qwen/Qwen3.5-0.8B \
    && (hf auth logout || true)

COPY server.py .

EXPOSE 8094

HEALTHCHECK --interval=15s --timeout=5s --start-period=120s --retries=20 \
    CMD curl -fsS http://localhost:8094/health || exit 1

# BRICK_CLASSIFIER_TOKEN is read by server.py at startup and protects /classify.
ENTRYPOINT ["python3", "server.py", "--port", "8094", "--device", "cuda"]
