# ─── .dockerignore ───
# Keep Docker build context lean — only what the multi-stage build needs.
# Build context = repo root; only apps/router/* is used by the Dockerfile.

# Git
.git
.gitignore
.gitattributes

# Documentation & paper
*.md
docs/
website/
reference/

# Monorepo siblings NOT used by router image
apps/cli/
packages/

# IDE / editor
.idea/
.vscode/
*.swp
*.swo

# Node.js
**/node_modules/
**/dist/

# Python environments / artifacts
.venv/
**/.venv/
__pycache__/
**/__pycache__/
*.pyc
*.egg-info/

# Evaluation & benchmarks (NOT runtime)
apps/router/benchmark/

# Deployment manifests (NOT runtime)
deploy/
.github/

# Training data & model weights (downloaded at runtime via HF)
models/
**/models/
*.pt
*.pth
*.bin
*.onnx
*.safetensors

# Build artifacts
**/target/
bin/
tools/bin/

# Dashboard (separate image)
dashboard/

# Secrets
.env
.env.*
**/.env
**/.hf_token*
**/regolo_api_key*

# Local runtimes
wandb/
.agents/
.codex/
.claude/

# OS
.DS_Store
Thumbs.db
