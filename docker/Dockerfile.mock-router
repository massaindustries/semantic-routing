FROM python:3.12-slim

WORKDIR /app

# Install dependencies (fastapi and uvicorn are already in requirements.txt)
COPY requirements.txt .
RUN pip install --no-cache-dir fastapi uvicorn

# Copy the mock router script
COPY mock_router.py .

# Expose the VSR port (default 8888)
EXPOSE 8888

# Run the mock router
CMD ["uvicorn", "mock_router:app", "--host", "0.0.0.0", "--port", "8888"]
